# Config Firebase Web (publique, mais hors du code — invariant 5).
# Copier en .env.local (dev) / .env.production (prod). Ne JAMAIS committer les .env.*.
# Valeurs depuis la console Firebase du PROJET PROPRE J1 (≠ projet AI Studio).
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
# ID de la base Firestore (nommée) ; "(default)" pour la base par défaut.
VITE_FIREBASE_DATABASE_ID="(default)"

# Région des Cloud Functions (doit matcher functions FUNCTIONS_REGION). IMMUABLE une fois en prod.
VITE_FUNCTIONS_REGION="us-central1"

# Mettre "true" pour brancher la SPA sur la suite d'émulateurs locaux.
VITE_USE_EMULATORS="false"

# App Check (reCAPTCHA v3). Site key publique. En dev, jeton debug depuis la console.
VITE_APPCHECK_SITE_KEY=""
VITE_APPCHECK_DEBUG_TOKEN=""

# Notifications push (Firebase Cloud Messaging). Clé VAPID publique — Console Firebase >
# Paramètres du projet > Cloud Messaging > Certificats Web Push. Sans elle, le bouton
# "Activer les notifications" reste désactivé (dégradation silencieuse, pas d'erreur).
# Penser aussi à renseigner la même config Firebase dans public/firebase-messaging-sw.js
# (un service worker ne peut pas lire les variables d'environnement Vite).
VITE_FCM_VAPID_KEY=""
