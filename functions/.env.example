# ─────────────────────────────────────────────────────────────────────────────
# Secrets & config des Cloud Functions — Thie Thie Services
# Ce fichier est un MODÈLE committé. NE PAS y mettre de vraie valeur.
# ─────────────────────────────────────────────────────────────────────────────
#
# Convention du projet : les secrets vivent dans un fichier d'env spécifique au projet,
# GITIGNORÉ (`.env*`), chargé automatiquement au déploiement ET par l'émulateur :
#
#     functions/.env.thie-thie-services   (projet `thie-thie-services`)
#     functions/.env                       (défauts communs)
#     functions/.env.local                 (surcharges locales/émulateur)
#
# Les fonctions lisent ces valeurs via process.env (cf. lib/reloadly.ts, webhooks.ts…).
# Copier ce modèle vers functions/.env.thie-thie-services et remplir les vraies valeurs.
#
# (Durcissement futur : migrer TOUS ces secrets vers Google Secret Manager
#  `firebase functions:secrets:set` — audit §5.4. Ne PAS mélanger : une variable ne peut
#  pas être à la fois dans un .env ET déclarée en defineSecret, sinon le déploiement échoue.)
# ─────────────────────────────────────────────────────────────────────────────

# --- Fournisseur cartes cadeaux : Reloadly ---
RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=
# 'sandbox' (défaut, pour tester) ou 'live' (prod réelle).
RELOADLY_ENV=sandbox

# --- Passerelle crypto : OxaPay ---
OXAPAY_MERCHANT_API_KEY=
OXAPAY_CALLBACK_URL=

# --- Webhook SMS MonCash/NatCash (auto-crédit dépôts) ---
SMS_HOOK_SECRET=

# --- E-mail transactionnel (livraison codes) : Resend ---
RESEND_API_KEY=
RESEND_FROM=

# --- App Check / bootstrap / région ---
FUNCTIONS_ENFORCE_APPCHECK=false
FUNCTIONS_BOOTSTRAP_ADMIN_EMAILS=
FUNCTIONS_REGION=us-central1
